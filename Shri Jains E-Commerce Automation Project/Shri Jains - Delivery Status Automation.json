              "value": "=<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      padding: 40px;\n      font-size: 15px;\n      color: #000;\n    }\n\n    .header {\n      text-align: center;\n      margin-bottom: 30px;\n    }\n\n    .shop-name {\n      font-size: 30px;\n      font-weight: bold;\n    }\n\n    .shop-address {\n      font-size: 15px;\n      margin-top: 6px;\n    }\n\n    hr {\n      margin: 30px 0;\n      border: 1px solid #000;\n    }\n\n    .details {\n      width: 100%;\n      margin-bottom: 30px;\n      font-size: 16px;\n    }\n\n    .details td {\n      padding: 8px 0;\n    }\n\n    table {\n      width: 100%;\n      border-collapse: collapse;\n      margin-top: 20px;\n      font-size: 16px;\n    }\n\n    th, td {\n      border: 1px solid #000;\n      padding: 14px;\n      text-align: left;\n    }\n\n    th {\n      background-color: #f2f2f2;\n      font-size: 17px;\n    }\n\n    .total {\n      margin-top: 30px;\n      font-size: 20px;\n      font-weight: bold;\n      text-align: right;\n    }\n\n    .footer {\n      margin-top: 45px;\n      text-align: center;\n      font-size: 15px;\n    }\n  </style>\n</head>\n\n<body>\n\n  <div class=\"header\">\n    <div class=\"shop-name\">Shri Jains Stationery Mart</div>\n    <div class=\"shop-address\">\n      Arya Samaj Road, Rampura, Kota\n    </div>\n  </div>\n\n  <hr>\n\n  <table class=\"details\">\n    <tr>\n      <td><b>Order ID:</b> {{$json.orderId}}</td>\n      <td><b>Customer Name:</b> {{$json.customerName}}</td>\n    </tr>\n    <tr>\n      <td><b>Email:</b> {{$json.customerEmail}}</td>\n      <td><b>Address:</b> {{$json.address}}</td>\n    </tr>\n  </table>\n\n  <table>\n    <tr>\n      <th>Item Description</th>\n      <th>Payment Mode</th>\n      <th>Amount (₹)</th>\n    </tr>\n    <tr>\n      <td>{{ $json['Order Itmes'] }}</td>\n      <td>{{ $json.Mode }}</td>\n      <td>₹ {{ $json['Paid Amount'] }}</td>\n    </tr>\n  </table>\n\n  <div class=\"total\">\n    Total Amount Paid: ₹ {{ $json['Paid Amount'] }}\n  </div>\n\n  <div class=\"footer\">\n    Thank you for shopping with <b>Shri Jains Stationery Mart</b> <br>\n    Visit us again!\n  </div>\n\n</body>\n</html>\n",
              "type": "string"
            }
          ]
